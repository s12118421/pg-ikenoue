{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "cd /Users/ten/anim-gym && npx eslint --fix \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx eslint:*)",
      "Bash(npx vite:*)",
      "Bash(npm run:*)",
      "mcp__playwright_*"
    ]
  }
}
